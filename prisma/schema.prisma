
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())
  username String @unique
  email String @unique
  password String
  
  profilePicture String?
  ProfileBanner String?
  bio String?
  birthDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]
  comments Comment[]

  follower Follows[]
  follwing Follows[]

}

model Post {
  id String @id @default(cuid())
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  userId String

  comments Comment[]
}

model Comment {
  id String @id @default(cuid())
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  userId String

  post Post @relation(fields: [postId], references: [id])
  postId String
}

model Follows {
  follwer User @relation(fields: [followerId], references: [id])
  followerId String

  follwing User @relation(fields: [followingId], references: [id])
  followingId String
}